{
  "expo": {
    "name": "NavAble",
    "slug": "NavAble",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/NavAble.png",
    "scheme": [
      "frontend2",
      "com.googleusercontent.apps.147401588179-pp6a7j35v6rp5j6psqlfjq4j9e98rn40"
    ],
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.devdhawan.navable",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "NavAble uses your location to show your position on the campus map.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "NavAble uses your location in the background to provide live navigation updates and voice announcements.",
        "NSLocationAlwaysUsageDescription": "NavAble uses your location in the background to provide live navigation updates and voice announcements.",
        "UIBackgroundModes": [
          "location",
          "audio"
        ],
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "LSApplicationQueriesSchemes": [
          "comgooglemaps"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.dedhaw.frontend2"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "./plugins/with-google-street-view-ios",
      "./plugins/with-strip-aps-environment",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "NavAble uses your location to show your position on the campus map.",
          "locationAlwaysPermission": "NavAble uses your location in the background to provide live navigation updates and voice announcements.",
          "isIosBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-maps"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
